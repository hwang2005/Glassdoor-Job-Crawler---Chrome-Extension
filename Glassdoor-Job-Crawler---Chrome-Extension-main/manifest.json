{
  "manifest_version": 3,
  "name": "Glassdoor Job Crawler",
  "version": "2.3",
  "description": "Crawl job listings from Glassdoor with smart apply method detection (text → DOM heuristics → click-capture fallback), save to CSV",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.glassdoor.com/Job/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}