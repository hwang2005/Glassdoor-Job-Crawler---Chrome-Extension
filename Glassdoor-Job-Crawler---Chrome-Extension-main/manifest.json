{
  "manifest_version": 3,
  "name": "Glassdoor Job Crawler",
  "version": "2.4",
  "description": "Crawl job listings from Glassdoor with batch-optimised crawling and smart apply method detection, save to CSV",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.glassdoor.com/*",
        "https://*.glassdoor.co.uk/*",
        "https://*.glassdoor.co.in/*",
        "https://*.glassdoor.ca/*",
        "https://*.glassdoor.com.au/*",
        "https://*.glassdoor.sg/*",
        "https://*.glassdoor.de/*",
        "https://*.glassdoor.fr/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}